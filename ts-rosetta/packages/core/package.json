{
  "name": "@rosetta/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/cjs/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./dist/cjs/index.js"
    },
    "./styles.css": "./src/styles.css"
  },
  "scripts": {
    "test": "vitest run",
    "build": "tsc --noEmit && pnpm prepare",
    "prepare": "tsc -p tsconfig.cjs.json && node -e \"require('fs').writeFileSync('dist/cjs/package.json','{\\\"type\\\":\\\"commonjs\\\"}')\"",
    "demo:ts": "tsc -p js-vs-ts",
    "demo:js": "node js-vs-ts/discount.js"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
