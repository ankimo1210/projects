<Window x:Class="CsharpApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:CsharpApp.Converters"
        xmlns:viewModels="clr-namespace:CsharpApp.ViewModels"
        xmlns:views="clr-namespace:CsharpApp.Views"
        mc:Ignorable="d"
        Title="RealtimeTicker"
        Width="1100"
        Height="650"
        MinWidth="900"
        MinHeight="540"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        Background="#F3F5F7">
    <Window.Resources>
        <converters:PriceDirectionToBrushConverter x:Key="DirectionBrushConverter" />

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#DDE2E7" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="14,4" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#243447" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#C8D0D9" />
        </Style>

        <Style x:Key="RightAlignedCell" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="Margin" Value="8,0" />
        </Style>

        <Style x:Key="DirectionalCell" TargetType="TextBlock"
               BasedOn="{StaticResource RightAlignedCell}">
            <Setter Property="Foreground"
                    Value="{Binding Direction, Converter={StaticResource DirectionBrushConverter}}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="24,16"
                Background="#162433">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="76" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock FontSize="22"
                               FontWeight="Bold"
                               Foreground="White"
                               Text="RealtimeTicker" />
                    <TextBlock Margin="0,2,0,0"
                               FontSize="11"
                               Foreground="#9FB0C3"
                               Text="Offline GBM market simulation" />
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Command="{Binding StartCommand}" Content="▶  Start" />
                    <Button Command="{Binding PauseCommand}" Content="⏸  Pause" />
                </StackPanel>

                <StackPanel Grid.Column="4"
                            Margin="0,0,12,0"
                            VerticalAlignment="Center">
                    <TextBlock FontSize="11"
                               Foreground="#9FB0C3"
                               Text="UPDATE INTERVAL" />
                    <TextBlock FontSize="12"
                               FontWeight="SemiBold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="LIVE" />
                                <Setter Property="Foreground" Value="#6EE7A8" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRunning}" Value="False">
                                        <Setter Property="Text" Value="PAUSED" />
                                        <Setter Property="Foreground" Value="#F5B7B1" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <Slider x:Name="IntervalSlider"
                        Grid.Column="5"
                        Margin="0,0,12,0"
                        VerticalAlignment="Center"
                        Minimum="100"
                        Maximum="1000"
                        TickFrequency="50"
                        IsSnapToTickEnabled="True"
                        IsMoveToPointEnabled="True"
                        Value="{Binding UpdateIntervalMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Column="6"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="White"
                           TextAlignment="Right"
                           Text="{Binding UpdateIntervalMs, StringFormat={}{0} ms}" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.92*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="1.08*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Margin="18,16,18,12">
                        <TextBlock FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="#243447"
                                   Text="Instruments" />
                        <TextBlock Margin="0,3,0,0"
                                   FontSize="11"
                                   Foreground="#718096"
                                   Text="Select a row to inspect its rolling history" />
                    </StackPanel>

                    <DataGrid x:Name="TickerGrid"
                              Grid.Row="1"
                              ItemsSource="{Binding Instruments}"
                              SelectedItem="{Binding SelectedInstrument, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserReorderColumns="False"
                              CanUserResizeRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#EDF0F2"
                              BorderThickness="0"
                              RowHeaderWidth="0"
                              RowHeight="44"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              Background="White">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="views:PriceFlashBehavior.IsEnabled" Value="True" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="VerticalContentAlignment" Value="Center" />
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Height" Value="36" />
                                <Setter Property="Padding" Value="10,0" />
                                <Setter Property="FontSize" Value="11" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Setter Property="Foreground" Value="#718096" />
                                <Setter Property="Background" Value="#F8FAFB" />
                                <Setter Property="BorderBrush" Value="#E3E7EB" />
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Width="*"
                                                MinWidth="105"
                                                Header="SYMBOL"
                                                Binding="{Binding Symbol}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Margin" Value="10,0" />
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                        <Setter Property="FontWeight" Value="Bold" />
                                        <Setter Property="Foreground" Value="#243447" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Width="110"
                                                Header="LAST"
                                                Binding="{Binding Price, StringFormat={}{0:N2}}"
                                                ElementStyle="{StaticResource DirectionalCell}" />

                            <DataGridTextColumn Width="100"
                                                Header="CHANGE"
                                                Binding="{Binding ChangePercentText}"
                                                ElementStyle="{StaticResource DirectionalCell}" />

                            <DataGridTemplateColumn Width="74" Header="MOVE">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="15"
                                                   FontWeight="Bold"
                                                   Foreground="{Binding Direction, Converter={StaticResource DirectionBrushConverter}}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="–" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Direction}"
                                                                     Value="{x:Static viewModels:PriceDirection.Up}">
                                                            <Setter Property="Text" Value="▲" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Direction}"
                                                                     Value="{x:Static viewModels:PriceDirection.Down}">
                                                            <Setter Property="Text" Value="▼" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Padding="22"
                    Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="24" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="#718096"
                                       Text="SELECTED INSTRUMENT" />
                            <TextBlock Margin="0,4,0,0"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#243447"
                                       Text="{Binding SelectedInstrument.Symbol}" />
                        </StackPanel>
                        <Border Grid.Column="1"
                                Padding="10,5"
                                VerticalAlignment="Top"
                                Background="#EDF7F1"
                                CornerRadius="12">
                            <TextBlock FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="#2F855A"
                                       Text="300-POINT WINDOW" />
                        </Border>
                    </Grid>

                    <StackPanel Grid.Row="1" Margin="0,20,0,0">
                        <TextBlock FontSize="48"
                                   FontWeight="Light"
                                   Foreground="{Binding SelectedInstrument.Direction, Converter={StaticResource DirectionBrushConverter}}"
                                   Text="{Binding SelectedInstrument.Price, StringFormat={}{0:N2}}" />
                        <TextBlock Margin="2,0,0,0"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{Binding SelectedInstrument.Direction, Converter={StaticResource DirectionBrushConverter}}"
                                   Text="{Binding SelectedInstrument.ChangePercentText}" />
                    </StackPanel>

                    <Border Grid.Row="3"
                            Padding="8"
                            Background="#FAFBFC"
                            BorderBrush="#EDF0F2"
                            BorderThickness="1"
                            CornerRadius="8">
                        <views:SparklineControl x:Name="PriceChart"
                                                Values="{Binding SelectedInstrument.History}"
                                                Stroke="#356FD4"
                                                LineThickness="2.5" />
                    </Border>

                    <TextBlock Grid.Row="4"
                               Margin="0,12,0,0"
                               HorizontalAlignment="Right"
                               FontSize="11"
                               Foreground="#718096"
                               Text="Oldest  →  Latest" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
