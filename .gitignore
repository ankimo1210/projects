*.log
*_log.txt
backfill_log*.txt
sync_log*.txt
streamlit.log

# OS / Windows
.DS_Store
Thumbs.db
*:Zone.Identifier
~$*

# AI tooling scratch (brainstorm/plan artifacts)
.superpowers/

# Xcode per-user state
**/xcuserdata/

# LLM translation cache (models/ build scripts regenerate it)
**/translation_cache/

# Claude Code local settings / state (machine-specific)
.claude/settings.local.json
.claude/scheduled_tasks.lock
.claude/worktrees/

# PDFs and derived paper corpora are intentionally trackable workspace-wide.

# Generated outputs are intentionally trackable workspace-wide, regardless of
# file-type ignores above. Scratch outputs remain ephemeral.
!/**/outputs/
!/**/outputs/**
/_scratch/outputs/
