{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(**/*.csv)",
      "Read(**/*.parquet)",
      "Read(**/*.geojson)",
      "Read(**/*.duckdb)",
      "Read(**/*.duckdb.wal)",
      "Read(**/uv.lock)",
      "Read(**/package-lock.json)",
      "Read(**/pnpm-lock.yaml)"
    ]
  }
}
