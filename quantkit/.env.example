# Copy to .env and fill in the free API keys you have. All are optional for the
# MVP except FRED (needed for US/JP macro & rates). Stooq / Treasury / CoinGecko
# / Binance need no key.

# US macro & rates (free): https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Japan equities & fundamentals (free tier): https://jpx-jquants.com/
JQUANTS_REFRESH_TOKEN=

# Japan macro (free): https://www.e-stat.go.jp/api/
ESTAT_APP_ID=

# Optional US macro sources (Phase 2)
BEA_API_KEY=
BLS_API_KEY=
