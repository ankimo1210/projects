# ============================================================
# re_invest_os API — 環境変数サンプル
# このファイルをコピーして .env を作成し、値を埋める
#   cp apps/api/.env.example apps/api/.env
# ============================================================

# ------------------------------------------------------------
# LLM プロバイダー設定（どちらか一方を選択）
# ------------------------------------------------------------

# --- Anthropic Claude（本番推奨） ---
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001   # 省略時はこのモデルを使用

# --- Ollama（ローカル開発用） ---
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434       # 省略時はこのURLを使用
# OLLAMA_MODEL=qwen2.5:7b                     # 省略時はこのモデルを使用

# ------------------------------------------------------------
# データベース（省略時は SQLite を自動生成）
# ------------------------------------------------------------

# SQLite（開発用、省略可）
# DATABASE_URL=sqlite+aiosqlite:///./reio.db

# Supabase Postgres（本番用）
# DATABASE_URL=postgresql+asyncpg://postgres:<password>@<host>:5432/postgres

# ------------------------------------------------------------
# CORS（省略時は localhost:3000 のみ許可）
# ------------------------------------------------------------

# CORS_ALLOW_ORIGINS=http://localhost:3000,https://your-domain.com

# ------------------------------------------------------------
# その他（通常は変更不要）
# ------------------------------------------------------------

# プロンプトファイルの場所（省略時はパッケージ内の docs/prompts/ を使用）
# REINVEST_PROMPTS_DIR=/path/to/docs/prompts
