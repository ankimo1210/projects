<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ page_title }} — {{ site_title }}</title>
<script src="assets/plotly.min.js"></script>
<style>
  :root { --ink:#1a1a2e; --sub:#5a5a72; --line:#e3e3ee; --accent:#3b4fd8; --bg:#fafafd; }
  * { box-sizing:border-box; }
  body { font-family:"Hiragino Sans","Noto Sans JP","Yu Gothic UI",sans-serif; color:var(--ink);
         margin:0; background:var(--bg); line-height:1.75; }
  header { background:linear-gradient(135deg,#1a1a2e,#3b4fd8); color:#fff; padding:26px 24px 22px; }
  header h1 { margin:0; font-size:1.3rem; }
  header p { margin:4px 0 0; opacity:.8; font-size:.85rem; }
  nav { position:sticky; top:0; background:#fff; border-bottom:1px solid var(--line);
        padding:8px 16px; z-index:10; overflow-x:auto; white-space:nowrap; }
  nav a { color:var(--accent); text-decoration:none; margin-right:14px; font-size:.85rem; padding:3px 0; }
  nav a.active { font-weight:700; border-bottom:2px solid var(--accent); }
  main { max-width:1040px; margin:0 auto; padding:24px; }
  h2 { font-size:1.3rem; border-bottom:2px solid var(--accent); padding-bottom:8px; }
  h3 { font-size:1.03rem; margin:24px 0 8px; }
  .block { background:#fff; border:1px solid var(--line); border-radius:10px; padding:20px 24px; margin:18px 0; }
  .figwrap { overflow-x:auto; }
  dl.interp { background:#f5f6fc; border-left:4px solid var(--accent); border-radius:6px;
              padding:12px 16px; margin:10px 0 0; font-size:.86rem; }
  dl.interp dt { font-weight:700; color:var(--accent); margin-top:7px; }
  dl.interp dt:first-child { margin-top:0; }
  dl.interp dd { margin:2px 0 0; }
  table.kv { border-collapse:collapse; width:100%; font-size:.85rem; }
  table.kv td, table.kv th { border:1px solid var(--line); padding:6px 10px; text-align:left; vertical-align:top; }
  table.kv th { background:#f2f3fa; }
  pre { background:#f5f6fc; padding:12px; border-radius:6px; overflow-x:auto; font-size:.82rem; }
  code { font-family:"Cascadia Code",Consolas,monospace; font-size:.85em; }
  .gen-text { font-family:"Cascadia Code",Consolas,monospace; font-size:.8rem; white-space:pre-wrap; word-break:break-all; }
  footer { text-align:center; color:var(--sub); font-size:.78rem; padding:26px; }
</style>
</head>
<body>
<header>
  <h1>{{ site_title }}</h1>
  <p>全数値は実測値。各図に What / Why / How / Observation / Interpretation / Caveat / Next。</p>
</header>
<nav>
  {% for name, title in nav %}<a href="{{ name }}.html" {% if name == active %}class="active"{% endif %}>{{ title }}</a>{% endfor %}
</nav>
<main>
  <h2>{{ page_title }}</h2>
  {% for b in blocks %}
  <div class="block">
    {% if b.heading %}<h3>{{ b.heading }}</h3>{% endif %}
    {% if b.figure %}<div class="figwrap">{{ b.figure }}</div>{% endif %}
    {% if b.html %}{{ b.html }}{% endif %}
    {% if b.meta %}
    <dl class="interp">
      <dt>What</dt><dd>{{ b.meta.what }}</dd>
      <dt>Why</dt><dd>{{ b.meta.why }}</dd>
      <dt>How to read</dt><dd>{{ b.meta.how }}</dd>
      <dt>Observation</dt><dd>{{ b.meta.observation }}</dd>
      <dt>Interpretation</dt><dd>{{ b.meta.interpretation }}</dd>
      <dt>Caveat</dt><dd>{{ b.meta.caveat }}</dd>
      <dt>Next</dt><dd>{{ b.meta.next }}</dd>
    </dl>
    {% endif %}
  </div>
  {% endfor %}
</main>
<footer>jp_llm_lab — generated from saved experiment artifacts. Not a competitive LLM; a lab to make LLM internals observable.</footer>
</body>
</html>
