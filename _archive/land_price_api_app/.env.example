# 不動産情報ライブラリ API キー
# https://www.reinfolib.mlit.go.jp/ でアカウント登録後に取得
REINFOLIB_API_KEY=your_api_key_here

# DuckDB ファイルパス
# 未設定時は ../_data/land_price/processed/land_prices.duckdb を優先し、
# 未移行なら従来の ./data/processed/land_prices.duckdb にフォールバック
DUCKDB_PATH=../_data/land_price/processed/land_prices.duckdb

# ワークスペース共通データ配置
LAND_PRICE_RAW_DIR=../_data/land_price/raw
LAND_PRICE_PROCESSED_DIR=../_data/land_price/processed
LAND_PRICE_LOG_DIR=../_logs/app/land_price_api_app

# ログレベル（DEBUG / INFO / WARNING / ERROR）
LOG_LEVEL=INFO

# Anthropic API キー（物件分析タブの LLM 抽出に使用、省略可）
# https://console.anthropic.com/ で取得
ANTHROPIC_API_KEY=

# e-Stat API アプリケーション ID（賃貸相場データ同期に使用、省略可）
# https://api.e-stat.go.jp/ でアカウント登録後に取得
ESTAT_APP_ID=
